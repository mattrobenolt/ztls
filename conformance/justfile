[private]
default:
    @just --list

[doc("Lint Python code")]
lint:
    uv run ruff format --check .
    uv run ruff check .
    uv run ty check .

[doc("Format Python code")]
fmt:
    uv run ruff format .
    uv run ruff check --fix .

[private]
_build:
    zig build

[doc("Run tlsfuzzer TLS 1.3 conformance smoke tests")]
tlsfuzzer *args: _build
    uv run pytest {{ args }}

[doc("Run TLS-Anvil server tests")]
anvil-server: _build
    @echo "TODO: TLS-Anvil server runner not yet wired"

[doc("Run TLS-Anvil client tests")]
anvil-client: _build
    @echo "TODO: TLS-Anvil client runner not yet wired"
