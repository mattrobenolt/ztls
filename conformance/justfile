[private]
default:
    @just --list

[doc("Format conformance code")]
fmt: fmt-python fmt-zig fmt-just

[doc("Lint conformance code")]
lint: lint-python lint-zig lint-just

[doc("Format Python code")]
fmt-python:
    uv run ruff format .
    uv run ruff check --fix .

[doc("Lint Python code")]
lint-python:
    uv run ruff format --check .
    uv run ruff check .
    uv run ty check .

[doc("Format Zig harness code")]
fmt-zig:
    zig fmt build.zig src/

[doc("Lint Zig harness code")]
lint-zig:
    zig fmt --check build.zig src/
    ziglint build.zig src/

[doc("Format Justfile")]
fmt-just:
    just --fmt --unstable --justfile justfile

[doc("Lint Justfile")]
lint-just:
    just --check --fmt --unstable --justfile justfile

[private]
build:
    zig build

[doc("Run tlsfuzzer TLS 1.3 conformance smoke tests")]
tlsfuzzer *args: build
    uv run pytest {{ args }}

[doc("Run all CI gates")]
ci:
    just tlsfuzzer -v
    just anvil-report-test

[doc("Run TLS-Anvil server tests against the ztls server harness")]
anvil-server *args: build
    uv run python scripts/anvil_server.py {{ args }}

[doc("Normalize TLS-Anvil results: apply skip-list and emit summary.json / summary.txt")]
anvil-report results_json *args:
    uv run python scripts/anvil_report.py {{ results_json }} {{ args }}

[doc("Run synthetic TLS-Anvil report parser tests")]
anvil-report-test:
    uv run pytest -q tests/test_anvil_report.py

[doc("Lint the skip list against known TLS-Anvil feature names")]
anvil-report-skip-list:
    @echo "TODO: real-run skip-list audit not yet automated."
    @echo "Run 'just anvil-report <real-results> --output-dir <run-dir>' and review unmatched_skip_patterns in the summary."

[doc("Run TLS-Anvil client tests")]
anvil-client: build
    @echo "TODO: TLS-Anvil client runner not yet wired"
