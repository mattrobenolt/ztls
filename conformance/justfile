[doc("Lint Python code")]
lint:
    uv run ruff format --check .
    uv run ruff check .
    uv run ty check .

[doc("Format Python code")]
fmt:
    uv run ruff format .
    uv run ruff check --fix .

[private]
_build:
    zig build

[doc("Run tlsfuzzer TLS 1.3 conformance smoke tests")]
tlsfuzzer *args: _build
    uv run pytest {{ args }}

[doc("Run strict tlsfuzzer lockstep conversations")]
tlsfuzzer-lockstep: _build
    uv run pytest -q -m lockstep

[doc("Download TLS-Anvil release JAR and dependencies")]
anvil-fetch:
    ./anvil-fetch.sh

[doc("Run TLS-Anvil server tests")]
anvil-server: anvil-fetch _build
    ./run_anvil_server.py

[doc("Run TLS-Anvil client tests")]
anvil-client: anvil-fetch _build
    ./run_anvil_client.py

[doc("Clone BoringSSL and build the BoGo runner")]
bogo-fetch:
    ./bogo-fetch.sh

[doc("Run BoGo tests against the ztls shim")]
bogo: bogo-fetch _build
    ./run_bogo.sh
